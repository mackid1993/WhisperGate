<Application x:Class="WhisperGate.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="SettingsWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BgColor">#1E1E2E</Color>
            <Color x:Key="CardColor">#2A2A3C</Color>
            <Color x:Key="AccentColor">#5B9BD5</Color>
            <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
            <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="FgBrush" Color="White"/>
            <SolidColorBrush x:Key="FgDimBrush" Color="#99FFFFFF"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
