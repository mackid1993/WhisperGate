<Window x:Class="WhisperGate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperGate" Width="440" Height="620" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- WinUI3-style scrollbar: thin, rounded, fades in on hover -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#40FFFFFF" CornerRadius="2" Margin="0,2"
                                                        MinHeight="20"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Width" Value="6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- WinUI3-style slider -->
        <Style TargetType="Slider">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Track background (unfilled) -->
                            <Border Height="4" CornerRadius="2" Background="#30FFFFFF"
                                    Margin="8,0" VerticalAlignment="Center"/>
                            <!-- Track filled portion -->
                            <Canvas Height="4" Margin="8,0" VerticalAlignment="Center" ClipToBounds="True">
                                <Border x:Name="PART_SelectionRange" Height="4" CornerRadius="2"
                                        Background="{StaticResource AccentBrush}"/>
                            </Canvas>
                            <!-- Thumb track -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Grid>
                                                    <!-- Outer circle (hover ring) -->
                                                    <Ellipse Width="20" Height="20" Fill="Transparent"
                                                             Stroke="#30FFFFFF" StrokeThickness="0"
                                                             x:Name="HoverRing"/>
                                                    <!-- Inner circle (thumb) -->
                                                    <Ellipse Width="14" Height="14"
                                                             Fill="{StaticResource AccentBrush}"
                                                             Effect="{x:Null}"/>
                                                    <!-- Center dot -->
                                                    <Ellipse Width="6" Height="6" Fill="#FF1E1E2E"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HoverRing" Property="StrokeThickness" Value="2"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28,24,28,28">

            <!-- Header -->
            <TextBlock Text="WhisperGate" FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" Margin="0,0,0,2"/>
            <TextBlock Text="Noise gate for superwhisper" FontSize="13"
                       Foreground="{StaticResource FgTertiaryBrush}" Margin="0,0,0,20"/>

            <!-- Status Card -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                    Padding="16" Margin="0,0,0,20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status dot -->
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="{StaticResource FgTertiaryBrush}"
                             VerticalAlignment="Top" Margin="0,4,12,0"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="StatusText" Text="Standby" FontSize="15"
                                   FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                        <TextBlock x:Name="StatusDetail" Text="Waiting for superwhisper hotkey"
                                   FontSize="12" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,2,0,10"/>
                        <Border Background="#1AFFFFFF" CornerRadius="3" Height="4">
                            <Border x:Name="LevelFill" Background="{StaticResource AccentBrush}"
                                    CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Shortcuts Section -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="superwhisper Shortcuts" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Sync" Style="{StaticResource FluentButton}"
                        Click="OnSync" FontSize="12" Padding="12,4"/>
            </Grid>

            <!-- PTT Card -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                    Padding="14,10" Margin="0,0,0,4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Push to Talk" FontSize="13" Foreground="{StaticResource FgBrush}"/>
                        <TextBlock Text="Hold to record" FontSize="11" Foreground="{StaticResource FgTertiaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#20FFFFFF" CornerRadius="4" Padding="10,4"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="PttText" Text="Not Set" FontFamily="Cascadia Mono,Consolas"
                                   FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Toggle Recording Card -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                    Padding="14,10" Margin="0,0,0,20"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Toggle Recording" FontSize="13" Foreground="{StaticResource FgBrush}"/>
                        <TextBlock Text="Press to start/stop" FontSize="11" Foreground="{StaticResource FgTertiaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#20FFFFFF" CornerRadius="4" Padding="10,4"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="RecText" Text="Not Set" FontFamily="Cascadia Mono,Consolas"
                                   FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Noise Gate Section -->
            <TextBlock Text="Noise Gate" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" Margin="0,0,0,4"/>
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{StaticResource FgTertiaryBrush}" Margin="0,0,0,10"
                       Text="WhisperGate reduces your mic volume when you're not speaking, then boosts it to 100% the instant you start talking. Your original volume is restored when you stop dictating. Adjust both settings so the gate opens reliably when you speak but stays closed during silence."/>

            <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                    Padding="16" Margin="0,0,0,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Threshold" FontSize="13" Foreground="{StaticResource FgSecondaryBrush}"/>
                        <TextBlock x:Name="ThresholdValue" Grid.Column="1" Text="-40 dB"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="13"
                                   Foreground="{StaticResource FgBrush}"/>
                    </Grid>
                    <Slider x:Name="ThresholdSlider" Minimum="-60" Maximum="-20" Value="-40"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="OnThresholdChanged"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Foreground="{StaticResource FgTertiaryBrush}" Margin="0,6,0,12"
                               Text="Controls when audio passes through. Start at -40 dB and adjust: if the gate doesn't open when you speak, move left (more sensitive). If background noise leaks through, move right (less sensitive). Watch the level meter while talking to find the sweet spot."/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gated Volume" FontSize="13" Foreground="{StaticResource FgSecondaryBrush}"/>
                        <TextBlock x:Name="ReductionValue" Grid.Column="1" Text="20%"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="13"
                                   Foreground="{StaticResource FgBrush}"/>
                    </Grid>
                    <Slider x:Name="ReductionSlider" Minimum="5" Maximum="50" Value="20"
                            IsSnapToTickEnabled="True" TickFrequency="5"
                            ValueChanged="OnReductionChanged"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Foreground="{StaticResource FgTertiaryBrush}" Margin="0,6,0,0"
                               Text="Mic volume while you're not speaking. Lower = less background noise but the gate may struggle to detect your voice. Higher = gate detects speech more easily but more noise leaks. Start at 20% — if the gate doesn't reopen when you speak, increase it. If you hear too much noise, decrease it."/>
                </StackPanel>
            </Border>

            <!-- Start at Login -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                    Padding="14,10" Margin="0,12,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Start at Login" FontSize="13" Foreground="{StaticResource FgBrush}"
                               VerticalAlignment="Center"/>
                    <CheckBox x:Name="StartAtLoginCheck" Grid.Column="1"
                              Checked="OnStartAtLoginChanged" Unchecked="OnStartAtLoginChanged"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
</Window>
