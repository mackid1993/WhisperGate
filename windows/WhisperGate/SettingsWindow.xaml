<Window x:Class="WhisperGate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperGate" Width="440" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Header -->
            <TextBlock Text="WhisperGate" FontSize="22" FontWeight="Bold" Foreground="{StaticResource FgBrush}"/>
            <TextBlock Text="Noise gate for superwhisper" Foreground="{StaticResource FgDimBrush}" Margin="0,2,0,16"/>

            <!-- Status Card -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="StatusText" Text="Standby" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource FgBrush}"/>
                    <TextBlock x:Name="StatusDetail" Text="Waiting for superwhisper hotkey" Foreground="{StaticResource FgDimBrush}" Margin="0,4,0,8"/>
                    <ProgressBar x:Name="LevelBar" Minimum="0" Maximum="100" Value="0" Height="6"
                                 Foreground="{StaticResource AccentBrush}" Background="#333345"/>
                </StackPanel>
            </Border>

            <!-- Shortcuts -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="superwhisper Shortcuts" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Sync" Click="OnSync" Padding="12,4" Background="{StaticResource CardBrush}" Foreground="{StaticResource FgBrush}" BorderBrush="{StaticResource AccentBrush}"/>
            </Grid>

            <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Push to Talk" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="8,3">
                        <TextBlock x:Name="PttText" Text="Not Set" FontFamily="Consolas" Foreground="White" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Toggle Recording" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="8,3">
                        <TextBlock x:Name="RecText" Text="Not Set" FontFamily="Consolas" Foreground="White" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Threshold -->
            <TextBlock Text="Noise Gate" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource FgBrush}" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Threshold" Foreground="{StaticResource FgDimBrush}"/>
                <TextBlock x:Name="ThresholdValue" Grid.Column="1" Text="-40 dB" FontFamily="Consolas" Foreground="{StaticResource FgBrush}"/>
            </Grid>
            <Slider x:Name="ThresholdSlider" Minimum="-60" Maximum="-20" Value="-40"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    ValueChanged="OnThresholdChanged" Margin="0,0,0,4"/>
            <TextBlock Text="Set just above your room noise level." Foreground="{StaticResource FgDimBrush}" FontSize="11" Margin="0,0,0,16"/>

        </StackPanel>
    </ScrollViewer>
</Window>
